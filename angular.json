{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": "d1eb6217-fc23-43e0-a175-433f8cc38105"
  },
  "newProjectRoot": "projects",
  "projects": {
    "reportes-mf": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-builders/custom-webpack:browser",
          "options": {
            "outputPath": "dist/reportes-mf",
            "index": "src/index.html",
            "main": "src/main.single-spa.ts",
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "customWebpackConfig": {
              "path": "extra-webpack.config.js",
              "libraryName": "reportes-mf",
              "libraryTarget": "umd"
            },
            "assets": [
              {
                "glob": "**/*",
                "input": "src/assets",
                "output": "/assets/"
              }
            ]
          },
          "configurations": {
            "production": {
              "optimization": true,
              "outputHashing": "none",
              "sourceMap": false,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "buildOptimizer": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.production.ts"
                }
              ],
              "deployUrl": "https://reportes.portaloas.udistrital.edu.co/"
            },
            "development": {
              "optimization": true,
              "outputHashing": "none",
              "sourceMap": false,
              "namedChunks": false,
              "aot": true,
              "extractLicenses": true,
              "buildOptimizer": true,
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.development.ts"
                }
              ],
              "deployUrl": "https://pruebasreportes.portaloas.udistrital.edu.co/"
            },
            "local": {
              "buildOptimizer": false,
              "optimization": false,
              "vendorChunk": true,
              "extractLicenses": false,
              "sourceMap": true,
              "namedChunks": true,
              "outputHashing": "none",
              "deployUrl": "http://localhost:4226/"
            }
          },
          "defaultConfiguration": "local"
        },
        "serve": {
          "builder": "@angular-builders/custom-webpack:dev-server",
          "options": {
            "port": 4226
          },
          "configurations": {
            "production": {
              "buildTarget": "reportes-mf:build:production"
            },
            "development": {
              "buildTarget": "reportes-mf:build:development"
            },
            "local": {
              "buildTarget": "reportes-mf:build:local"
            }
          },
          "defaultConfiguration": "local"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}