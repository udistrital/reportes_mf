{
  "name": "reportes-mf",
  "version": "1.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node set-env.js && ng serve --port 4226",
    "build": "node set-env.js && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "build:single-spa:sga-cliente-evaluacion-docente-mf": "ng build sga-cliente-evaluacion-docente-mf --configuration production",
    "serve:single-spa:sga-cliente-evaluacion-docente-mf": "ng s --project sga-cliente-evaluacion-docente-mf --disable-host-check --port 4226 --live-reload false",
    "build:prod": "node set-env.js && ng build --progress --configuration=production",
    "build:test": "node set-env.js && ng build --progress --configuration=development"
  },
  "private": true,
  "packageManager": "npm@11.11.0",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^17.0.0",
    "dotenv": "^17.4.2",
    "rxjs": "~7.8.0",
    "single-spa-angular": "^21.0.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-builders/custom-webpack": "^21.0.3",
    "@angular/build": "^21.2.8",
    "@angular/cli": "^21.2.8",
    "@angular/compiler-cli": "^21.2.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
